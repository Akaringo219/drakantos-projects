<aside>
      <div class="sidebar">
            <div class="sidebar-container">

{% set notes = collections.all | filter(attribute="data.dg-publish") %}
{% set tree = {} %}

{# ノートを階層構造に変換 #}
{% for note in notes %}
  {% set path = note.data["dg-path"] | split("/") %}

  {# index は親扱い #}
  {% if path[path.length - 1] == "index" %}
    {% set path = path.slice(0, path.length - 1) %}
  {% endif %}

  {% set current = tree %}
  {% for segment in path %}
    {% if not current[segment] %}
      {% set current = current.update({ (segment): { "_children": {}, "_note": null } }) %}
    {% endif %}
    {% set current = current[segment] %}
    {% set current = current.update({ "_children": current._children }) %}
    {% set current = current._children %}
  {% endfor %}

  {# 最後のノードに note を紐づける #}
  {% set parent = tree %}
  {% for segment in path %}
    {% set parent = parent[segment] %}
  {% endfor %}
  {% set parent = parent.update({ "_note": note }) %}
{% endfor %}

{# 再帰描画 #}
{% macro render(node) %}
  <ul>
    {% for key, value in node %}
      {% if key != "_note" and key != "_children" %}
        <li>
          {% if value._note %}
            <a href="{{ value._note.url }}">{{ value._note.data.title }}</a>
          {% else %}
            {{ key }}
          {% endif %}
          {{ render(value._children) }}
        </li>
      {% endif %}
    {% endfor %}
  </ul>
{% endmacro %}

{{ render(tree) }}

            </div>
      </div>
</aside>
